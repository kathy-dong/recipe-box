# Supabase — from your project's Settings → API page
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Gemini — from aistudio.google.com (free tier)
GEMINI_API_KEY=your_gemini_api_key

# Optional: passphrase for the iOS Shortcut quick-add feature
QUICK_ADD_KEY=your-passphrase

# Optional: your production URL (used on the /share page)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
